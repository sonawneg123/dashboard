# ================================================================
#  NexusDB — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to version control.
# ================================================================

# ── Flask ─────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_32_CHARS_MIN

# ── MySQL RDS ─────────────────────────────────────────────────────
DB_HOST=your-rds-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=usermanagement
DB_USER=admin
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# ── Gunicorn ──────────────────────────────────────────────────────
GUNICORN_WORKERS=5
GUNICORN_THREADS=4
LOG_LEVEL=info

# ── AWS (optional — for Secrets Manager) ─────────────────────────
AWS_REGION=us-east-1
# AWS_SECRET_NAME=nexusdb/rds/credentials
